            <a href="#" data-turbo-frame="main-content" class="block px-6 py-2 text-gray-600 hover:bg-gray-50 italic">Organisation ⌵</a>
            <a href="#" data-turbo-frame="main-content" class="block px-6 py-2 text-gray-600 hover:bg-gray-50 italic">Reports ⌵</a>
            <a href="#" data-turbo-frame="main-content" class="block px-6 py-6 text-gray-500 hover:bg-gray-50 border-t">⚙️ Settings</a>
        </nav>
    </aside> #}

    <main class="flex-1 p-8 overflow-y-auto">
        
        <header class="flex justify-between items-center mb-8">
            <div class="relative w-1/3">
                <span class="absolute inset-y-0 left-0 pl-3 flex items-center text-gray-400">🔍</span>
                <input type="text" placeholder="Search..." class="border py-2 pr-3 pl-10 rounded w-full focus:outline-none focus:ring-2 focus:ring-blue-500 bg-white">
            </div>
            <div class="flex gap-6 items-center">
                <span class="text-xl cursor-pointer">🔔</span>
                <div class="w-10 h-10 bg-gray-300 rounded-full flex items-center justify-center text-white font-bold cursor-pointer">👤</div>
            </div>
        </header>

        <div class="mb-8">
            <h1 class="text-2xl font-bold text-gray-800">Add New Product</h1>
            <p class="text-gray-500 mt-1">Create a new product in your inventory</p>
        </div>

        <div class="bg-white border rounded-xl shadow-sm p-8 mb-6 max-w-5xl">
            <h2 class="text-lg font-bold text-gray-800 mb-6 border-b pb-2">Basic Information</h2>
            
            <form action="#" method="POST">
                <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
                    
                    <div class="md:col-span-2">
                        <label class="block text-sm font-semibold text-gray-700 mb-2">
                            Product Name <span class="text-red-500">*</span>
                        </label>
                        <input type="text" placeholder="Enter product name..." required
                               class="w-full border border-gray-300 rounded-lg px-4 py-2.5 focus:ring-2 focus:ring-blue-500 focus:outline-none bg-gray-50">
                    </div>

                    <div class="flex flex-col gap-6">
                        
                        <div>
                            <label class="block text-sm font-semibold text-gray-700 mb-2">
                                Unit <span class="text-red-500">*</span>
                            </label>
                            <select class="w-full border border-gray-300 rounded-lg px-4 py-2.5 focus:ring-2 focus:ring-blue-500 focus:outline-none bg-white cursor-pointer" required>
                                <option value="" disabled selected>Select Unit</option>
                                <option value="rame">Rame</option>
                                <option value="Boite">Boite</option>
                                <option value=" Piece">Piece</option>
                                <option value="Toner">Toner</option>
                                <option value="Paquet">Paquet</option>
                                <option value="Lot">Lot</option>
                            </select>
                        </div>

                        <div>
                            <label class="block text-sm font-semibold text-gray-700 mb-2">
                                Category <span class="text-red-500">*</span>
                            </label>
                            <select onchange="handleCategorySelect(this)" class="w-full border border-gray-300 rounded-lg px-4 py-2.5 focus:ring-2 focus:ring-blue-500 focus:outline-none bg-white cursor-pointer text-gray-700" required>
                                <option value="" disabled selected>Select Category</option>
                                <option value="1">Electronics</option>
                                <option value="2">Furniture</option>
                                <option value="3">Hardware</option>
                                <option value="new_category" class="font-bold text-blue-600 bg-blue-50">➕ Add New Category...</option>
                            </select>
                        </div>

                        <div>
                            <label class="block text-sm font-semibold text-gray-700 mb-2">
                                Sub Category <span class="text-red-500">*</span>
                            </label>
                            <select onchange="handleSubCategorySelect(this)" class="w-full border border-gray-300 rounded-lg px-4 py-2.5 focus:ring-2 focus:ring-blue-500 focus:outline-none bg-white cursor-pointer text-gray-700" required>
                                <option value="" disabled selected>Select Sub Category</option>
                                <option value="1">Laptops (Electronics)</option>
                                <option value="2">Desks (Furniture)</option>
                                <option value="new_subcategory" class="font-bold text-blue-600 bg-blue-50">➕ Add New Sub Category...</option>
                            </select>
                        </div>

                    </div>
                </div>

                <div class="mt-10 flex justify-end gap-4 border-t pt-6">
                    <a href="{{ path('app_produit_index') }}" class="px-6 py-2.5 border rounded-lg text-gray-600 hover:bg-gray-50 font-semibold transition-colors">
                        Cancel
                    </a>
                    <button type="submit" class="px-6 py-2.5 bg-blue-600 text-white rounded-lg hover:bg-blue-700 font-semibold shadow transition-colors">
                        Save Product
                    </button>
                </div>
            </form>
        </div>

        <div id="modal-category" class="hidden fixed inset-0 bg-gray-900 bg-opacity-50 z-50 flex items-center justify-center backdrop-blur-sm">
            <div class="bg-white rounded-xl shadow-xl w-full max-w-md p-6 relative">
                <button onclick="closeModal('modal-category')" class="absolute top-4 right-4 text-gray-400 hover:text-gray-600 text-xl font-bold">&times;</button>
                <h3 class="text-xl font-bold text-gray-800 mb-6">Add New Category</h3>
                <div class="mb-6">
                    <label class="block text-sm font-semibold text-gray-700 mb-2">Category Name</label>
                    <input type="text" placeholder="e.g., Electronics" class="w-full border rounded-lg px-4 py-2.5 focus:ring-2 focus:ring-blue-500 focus:outline-none bg-gray-50">
                </div>
                <div class="flex justify-end gap-3">
                    <button onclick="closeModal('modal-category')" class="px-5 py-2 border rounded-lg text-gray-600 hover:bg-gray-50 font-semibold">Cancel</button>
                    <button class="px-5 py-2 bg-blue-600 text-white rounded-lg hover:bg-blue-700 font-semibold">Add Category</button>
                </div>
            </div>
        </div>

        <div id="modal-subcategory" class="hidden fixed inset-0 bg-gray-900 bg-opacity-50 z-50 flex items-center justify-center backdrop-blur-sm">
            <div class="bg-white rounded-xl shadow-xl w-full max-w-md p-6 relative">
                <button onclick="closeModal('modal-subcategory')" class="absolute top-4 right-4 text-gray-400 hover:text-gray-600 text-xl font-bold">&times;</button>
                <h3 class="text-xl font-bold text-gray-800 mb-6">Add New Sub Category</h3>
                <div class="mb-4">
                    <label class="block text-sm font-semibold text-gray-700 mb-2">Parent Category</label>
                    <select class="w-full border rounded-lg px-4 py-2.5 focus:ring-2 focus:ring-blue-500 focus:outline-none bg-gray-50">
                        <option>Electronics</option>
                        <option>Furniture</option>
                    </select>
                </div>
                <div class="mb-6">
                    <label class="block text-sm font-semibold text-gray-700 mb-2">Sub Category Name</label>
                    <input type="text" placeholder="e.g., Laptops" class="w-full border rounded-lg px-4 py-2.5 focus:ring-2 focus:ring-blue-500 focus:outline-none bg-gray-50">
                </div>
                <div class="flex justify-end gap-3">
                    <button onclick="closeModal('modal-subcategory')" class="px-5 py-2 border rounded-lg text-gray-600 hover:bg-gray-50 font-semibold">Cancel</button>
                    <button class="px-5 py-2 bg-blue-600 text-white rounded-lg hover:bg-blue-700 font-semibold">Add Sub Category</button>
                </div>
            </div>
        </div>

    </main>
</div>


<script>
    function handleCategorySelect(selectElement) {
        if (selectElement.value === 'new_category') {
            document.getElementById('modal-category').classList.remove('hidden');
            selectElement.value = ''; 
        }
    }
    function handleSubCategorySelect(selectElement) {
        if (selectElement.value === 'new_subcategory') {
            document.getElementById('modal-subcategory').classList.remove('hidden');
            selectElement.value = ''; 
        }
    }
    function closeModal(modalId) {
        document.getElementById(modalId).classList.add('hidden');
    }
</script>

{% endblock %}