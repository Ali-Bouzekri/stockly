{% extends 'base.html.twig' %}

{% block title %}Products Inventory - Bouzekri Solutions{% endblock %}

{% block body %}

<div class="flex h-screen bg-gray-100">
    

    <main class="flex-1 overflow-hidden">
    <div class="sticky top-0 z-30 bg-gray-100 px-8 pt-8 pb-4">

<header class="flex justify-end items-center mb-8">
    <div class="flex gap-6 items-center">
        <span class="text-xl cursor-pointer">🔔</span>
        <div class="w-10 h-10 bg-gray-300 rounded-full flex items-center justify-center text-white font-bold cursor-pointer">👤</div>
    </div>
</header>

<div class="flex justify-between items-end mb-8">
    <div>
        <h1 class="text-2xl font-bold text-gray-800">Products Inventory</h1>
        <p class="text-gray-500 mt-1">Manage your products catalog and stock levels</p>
    </div>

    <button onclick="toggleModal()" 
   class="bg-blue-600 text-white px-6 py-2.5 rounded-lg font-bold shadow hover:bg-blue-700 transition-colors flex items-center gap-2">
   <span>+</span> Add New Product
</button>
</div>

<div class="bg-white border rounded-xl p-4 flex gap-4 items-center shadow-sm">

        
            <div class="relative flex-1">
                <span class="absolute inset-y-0 left-0 pl-3 flex items-center text-gray-400">🔍</span>
                <input type="text" id="product-search" placeholder="Search products..." class="border py-2 pr-3 pl-10 rounded w-full bg-gray-50 focus:outline-none focus:ring-1 focus:ring-blue-500">               </div>
            
            <div class="flex gap-3 items-center">
    <select id="cat-filter" class="border rounded-lg py-2 px-4 text-gray-600 bg-gray-50 focus:outline-none cursor-pointer">
        <option value="all">Category: All</option>
        {% for cat in categories %}
            {# Note: Check if it is nomCategory or nomCategorie in your Entity #}
            <option value="{{ cat.nomCategory|trim|lower }}">
    {{ cat.nomCategory }}
</option>
        {% endfor %}
    </select>

    <select id="sub-cat-filter" class="border rounded-lg py-2 px-4 text-gray-600 bg-gray-50">

<option value="all" data-parent="all">Subcategory: All</option>

{% for sub in sous_categories %}
<option
value="{{ sub.nomSousCat|trim|lower }}"
data-parent="{{ sub.categorie.nomCategory|trim|lower }}"
class="sub-option">

{{ sub.nomSousCat }}

</option>
{% endfor %}

</select>
    <select id="status-filter" class="border rounded-lg py-2 px-4 text-gray-600 bg-gray-50 focus:outline-none cursor-pointer">
        <option value="all">Status: All</option>
        <option value="in_stock">In Stock</option>
        <option value="low_stock">Low Stock</option>
        <option value="out_of_stock">Out of Stock</option>
    </select>

    <button onclick="exportToPDF()"
        class="border border-gray-300 rounded-lg py-2 px-4 text-gray-700 hover:bg-gray-50 flex items-center gap-2 font-medium transition-colors">
    📥 Export PDF
</button>
</div>
        </div>
</div>
        <div class="bg-white border rounded-xl shadow-sm overflow-auto max-h-[70vh]">
            <table class="w-full text-left border-collapse">
                <thead class="sticky top-0 z-20">
                    <tr class="bg-gray-50 border-b">
                        <th class="py-4 px-6 font-semibold text-gray-600">Product Name</th>
                        <th class="py-4 px-6 font-semibold text-gray-600">Category</th>
                        <th class="py-4 px-6 font-semibold text-gray-600">Stock Level</th>
                        <th class="py-4 px-6 font-semibold text-gray-600">Unit</th>
                        <th class="py-4 px-6 font-semibold text-gray-600">Status</th>
                        <th class="py-4 px-6 font-semibold text-gray-600 text-center">Actions</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-gray-100">
                    {% for produit in produits %}
                        
                        {# --- EXACT STATUS LOGIC --- #}
                        {% set stockStatus = 'In Stock' %}
                        {% set badgeClass = 'bg-green-100 text-green-700' %}
                        {% set barClass = 'bg-green-500' %}
                        
                        {% if produit.qteStock == 0 %}
                            {% set stockStatus = 'Out of Stock' %}
                            {% set badgeClass = 'bg-red-100 text-red-700' %}
                            {% set barClass = 'bg-red-500' %}
                        {% elseif produit.qteStock <= produit.seuilAlert %}
                            {% set stockStatus = 'Low Stock' %}
                            {% set badgeClass = 'bg-orange-100 text-orange-700' %}
                            {% set barClass = 'bg-orange-500' %}
                        {% endif %}

                        {# Progress bar math (max capped at 100 for visual) #}
                        {% set percent = min((produit.qteStock / 100) * 100, 100) %}

                        <tr class="product-item" data-id="{{ produit.idProduit }}"

                            data-category="{{ produit.sousCategorie and produit.sousCategorie.categorie 
                            ? produit.sousCategorie.categorie.nomCategory|trim|lower : '' }}"

                            data-subcategory="{{ produit.sousCategorie 
                            ? produit.sousCategorie.nomSousCat|trim|lower : '' }}"

                            data-status="{{ stockStatus|lower|replace({' ':'_'}) }}">

                            <td class="py-4 px-6 font-bold text-gray-800">{{ produit.designation }}</td>
                            
                            <td class="py-4 px-6 text-gray-600">
                                {{ produit.sousCategorie ? produit.sousCategorie.nomSousCat : '-' }}
                            </td>
                            
                            <td class="py-4 px-6">
                                <div class="flex flex-col gap-1 w-32">
                                    <div class="flex justify-between text-xs font-semibold text-gray-500">
                                        <span>{{ produit.qteStock }}</span>
                                        <span>{{ percent|round }}%</span>
                                    </div>
                                    <div class="w-full bg-gray-200 rounded-full h-1.5 border border-gray-300">
                                        <div class="{{ barClass }} h-1.5 rounded-full" style="width: {{ percent }}%"></div>
                                    </div>
                                </div>
                            </td>
                            
                            <td class="py-4 px-6 text-gray-500 text-sm">
                                {{ produit.unite ? produit.unite.nomunite : '-' }}
                            </td>
                            
                            <td class="py-4 px-6">
                                <span class="px-3 py-1 rounded-full text-xs font-bold {{ badgeClass }}">
                                    {{ stockStatus }}
                                </span>
                            </td>
                            
                            <td class="py-4 px-6 text-center relative group cursor-pointer">
                                <span class="text-gray-400 hover:text-gray-800 text-xl">•••</span>
                                
                                <div class="absolute right-8 top-8 w-32 bg-white border rounded-lg shadow-xl hidden group-hover:block z-10 text-left overflow-hidden">
                                    <a href="#"
                                        onclick="openEditModal(this)"
                                        data-id="{{ produit.idProduit }}"
                                        data-designation="{{ produit.designation }}"
                                        data-stock="{{ produit.qteStock }}"
                                        data-seuil="{{ produit.seuilAlert }}"
                                        data-description="{{ produit.description }}"
                                        data-cat-id="{{ produit.sousCategorie ? produit.sousCategorie.categorie.idCategory : '' }}"
                                        data-sub-id="{{ produit.sousCategorie ? produit.sousCategorie.idSousCat : '' }}"
                                        data-sub-name="{{ produit.sousCategorie ? produit.sousCategorie.nomSousCat : '' }}"
                                        data-unite-id="{{ produit.unite ? produit.unite.idUnite : '' }}">
                                        ✏️ Edit
                                    </a>
                                    
                                  
                                    <form method="post"
      action="{{ path('app_produit_delete', {'idProduit': produit.idProduit}) }}"
      onsubmit="return confirm('Delete this product?');">

<input type="hidden" name="_token" value="{{ csrf_token('delete' ~ produit.idProduit) }}">

<button type="button"
        onclick="deleteProduct({{ produit.idProduit }}, '{{ csrf_token('delete' ~ produit.idProduit) }}')"
        class="w-full text-left px-4 py-2 text-sm text-red-600 hover:bg-red-50 font-semibold">
    🗑️ Delete
</button>

</form>
                                </div>
                            </td>
                        </tr>
                    {% else %}
                        <tr data-id="{{ produit.idProduit }}">
                            <td colspan="6" class="py-8 text-center text-gray-500">
                                No products found. <a href="{{ path('app_produit_new') }}" class="text-blue-600 hover:underline">Create one?</a>
                            </td>
                        </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>
    </main>
</div>
{# ===== ADD PRODUCT MODAL (inline form, no iframe) ===== #}
<div id="productModal" class="fixed inset-0 z-50 flex items-center justify-center hidden">
    <div class="absolute inset-0 bg-gray-900 bg-opacity-50 backdrop-blur-sm" onclick="toggleModal()"></div>

    <div class="bg-white rounded-2xl shadow-2xl z-10 w-full max-w-2xl overflow-hidden">

        {# Modal Header #}
        <div class="px-8 py-5 border-b flex justify-between items-center">
            <div>
                <h3 class="text-xl font-bold text-gray-800">Add New Product</h3>
                <p class="text-gray-500 text-sm mt-0.5">Fill in the details below to add a product</p>
            </div>
            <button onclick="toggleModal()" class="text-gray-400 hover:text-gray-600 text-2xl leading-none">&times;</button>
        </div>

        {# Success / Error banner (hidden by default) #}
        <div id="modal-alert" class="hidden mx-8 mt-4 px-4 py-3 rounded-lg text-sm font-semibold"></div>

        {# Modal Form #}
        <form id="addProductForm" class="px-8 py-6 space-y-5">

            {# Row 1: Product Name #}
            <div>
                <label class="block text-sm font-semibold text-gray-700 mb-1">
                    Product Name <span class="text-red-500">*</span>
                </label>
                <input type="text" name="designation" id="add-designation" 
                    class="w-full border border-gray-300 rounded-lg px-4 py-2.5 bg-white focus:outline-none focus:ring-2 focus:ring-blue-500">
    <p class="text-xs text-gray-400 mt-1">The product name cannot be modified once created.</p>
            </div>

            {# Row 2: Category → SubCategory → Unit (3 columns) #}
            <div class="grid grid-cols-3 gap-4">

                <div>
                    <label class="block text-sm font-semibold text-gray-700 mb-1">
                        Category <span class="text-red-500">*</span>
                    </label>
                    <select id="modal-category" name="categorie"
                            class="w-full border border-gray-300 rounded-lg px-4 py-2.5 bg-white
                                   focus:outline-none focus:ring-2 focus:ring-blue-500 cursor-pointer">
                        <option value="">— Select —</option>
                        {% for cat in categories %}
                            <option value="{{ cat.idCategory }}">{{ cat.nomCategory }}</option>
                        {% endfor %}
                    </select>
                </div>

                <div>
                    <label class="block text-sm font-semibold text-gray-700 mb-1">
                        Subcategory <span class="text-red-500">*</span>
                    </label>
                    <select id="modal-subcategory" name="sousCategorie"
                            class="w-full border border-gray-300 rounded-lg px-4 py-2.5 bg-white
                                   focus:outline-none focus:ring-2 focus:ring-blue-500 cursor-pointer"
                            disabled>
                        <option value="">— Pick category first —</option>
                        {# Populated dynamically via JS #}
                        {% for sub in sous_categories %}
                            <option value="{{ sub.idSousCat }}"
                                    data-parent="{{ sub.categorie.idCategory }}">
                                {{ sub.nomSousCat }}
                            </option>
                        {% endfor %}
                    </select>
                </div>

                <div>
                    <label class="block text-sm font-semibold text-gray-700 mb-1">
                        Unit <span class="text-red-500">*</span>
                    </label>
                    <select name="unite"
                            class="w-full border border-gray-300 rounded-lg px-4 py-2.5 bg-white
                                   focus:outline-none focus:ring-2 focus:ring-blue-500 cursor-pointer">
                        <option value="">— Select —</option>
                        {% for unit in units %}
                            <option value="{{ unit.idUnite }}">{{ unit.nomunite }}</option>
                        {% endfor %}
                    </select>
                </div>

            </div>

            {# Row 3: Stock Qty + Alert Threshold #}
            <div class="grid grid-cols-2 gap-4">
                <div>
                    <label class="block text-sm font-semibold text-gray-700 mb-1">Initial Stock</label>
                    <input type="number" name="qteStock" value="0" min="0"
                           class="w-full border border-gray-300 rounded-lg px-4 py-2.5 bg-gray-50
                                  focus:outline-none focus:ring-2 focus:ring-blue-500">
                </div>
                <div>
                    <label class="block text-sm font-semibold text-gray-700 mb-1">Alert Threshold</label>
                    <input type="number" name="seuilAlert" value="0" min="0"
                           class="w-full border border-gray-300 rounded-lg px-4 py-2.5 bg-gray-50
                                  focus:outline-none focus:ring-2 focus:ring-blue-500">
                </div>
            </div>

            {# Row 4: Description (optional) #}
            <div>
                <label class="block text-sm font-semibold text-gray-700 mb-1">Description
                    <span class="text-gray-400 font-normal">(optional)</span>
                </label>
                <textarea name="description" rows="2" placeholder="Short description…"
                          class="w-full border border-gray-300 rounded-lg px-4 py-2.5 bg-gray-50
                                 focus:outline-none focus:ring-2 focus:ring-blue-500 resize-none"></textarea>
            </div>

            {# Footer buttons #}
            <div class="flex justify-end gap-3 pt-2 border-t">
                <button type="button" onclick="toggleModal()"
                        class="px-6 py-2.5 border rounded-lg text-gray-600 hover:bg-gray-50
                               font-semibold transition-colors">
                    Cancel
                </button>
                <button type="submit" id="submitBtn"
                        class="px-6 py-2.5 bg-blue-600 text-white rounded-lg hover:bg-blue-700
                               font-semibold shadow transition-colors flex items-center gap-2">
                    <span id="submitBtnText">Save Product</span>
                    <svg id="submitSpinner" class="hidden animate-spin h-4 w-4 text-white"
                         xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
                        <circle class="opacity-25" cx="12" cy="12" r="10"
                                stroke="currentColor" stroke-width="4"></circle>
                        <path class="opacity-75" fill="currentColor"
                              d="M4 12a8 8 0 018-8v8z"></path>
                    </svg>
                </button>
            </div>

        </form>
    </div>
    
</div>
{# ===== EDIT PRODUCT MODAL ===== #}
<div id="editProductModal" class="fixed inset-0 z-50 flex items-center justify-center hidden">
    <div class="absolute inset-0 bg-gray-900 bg-opacity-50 backdrop-blur-sm" onclick="toggleEditModal(false)"></div>

    <div class="bg-white rounded-2xl shadow-2xl z-10 w-full max-w-2xl overflow-hidden">

        {# Modal Header #}
        <div class="px-8 py-5 border-b flex justify-between items-center">
            <div>
                <h3 class="text-xl font-bold text-gray-800">Edit Product</h3>
                <p class="text-gray-500 text-sm mt-0.5">Update product details below</p>
            </div>
            <button onclick="toggleEditModal(false)" class="text-gray-400 hover:text-gray-600 text-2xl leading-none">&times;</button>
        </div>

        <div id="edit-modal-alert" class="hidden mx-8 mt-4 px-4 py-3 rounded-lg text-sm font-semibold"></div>

        <form id="editProductForm" class="px-8 py-6 space-y-5">

            <input type="hidden" name="idProduit" id="edit-idProduit">

            <div>
                <label class="block text-sm font-semibold text-gray-700 mb-1">
                    Product Name <span class="text-red-500">*</span>
                </label>
                <input type="text" name="designation" id="edit-designation"
                        placeholder="Enter new product name…"
                        class="w-full border border-gray-300 rounded-lg px-4 py-2.5 bg-white
                        focus:outline-none focus:ring-2 focus:ring-blue-500">
            </div>

            <div class="grid grid-cols-3 gap-4">
                <div>
                    <label class="block text-sm font-semibold text-gray-700 mb-1">Category</label>
                    <select id="edit-category" name="categorie"
                            class="w-full border border-gray-300 rounded-lg px-4 py-2.5 bg-white
                                   focus:outline-none focus:ring-2 focus:ring-blue-500 cursor-pointer">
                        <option value="">— Select —</option>
                        {% for cat in categories %}
                            <option value="{{ cat.idCategory }}">{{ cat.nomCategory }}</option>
                        {% endfor %}
                    </select>
                </div>

                <div>
                    <label class="block text-sm font-semibold text-gray-700 mb-1">Subcategory</label>
                    <select id="edit-subcategory" name="sousCategorie"
                            class="w-full border border-gray-300 rounded-lg px-4 py-2.5 bg-white
                                   focus:outline-none focus:ring-2 focus:ring-blue-500 cursor-pointer" disabled>
                        <option value="">— Pick category first —</option>
                        {% for sub in sous_categories %}
                            <option value="{{ sub.idSousCat }}" data-parent="{{ sub.categorie.idCategory }}">
                                {{ sub.nomSousCat }}
                            </option>
                        {% endfor %}
                    </select>
                </div>

                <div>
                    <label class="block text-sm font-semibold text-gray-700 mb-1">Unit</label>
                    <select name="unite" id="edit-unite"
                            class="w-full border border-gray-300 rounded-lg px-4 py-2.5 bg-white
                                   focus:outline-none focus:ring-2 focus:ring-blue-500 cursor-pointer">
                        <option value="">— Select —</option>
                        {% for unit in units %}
                            <option value="{{ unit.idUnite }}">{{ unit.nomunite }}</option>
                        {% endfor %}
                    </select>
                </div>
            </div>

            <div class="grid grid-cols-2 gap-4">
                <div>
                    <label class="block text-sm font-semibold text-gray-700 mb-1">Stock Qty</label>
                    <input type="number" name="qteStock" id="edit-qteStock" min="0"
                           class="w-full border border-gray-300 rounded-lg px-4 py-2.5 bg-gray-50
                                  focus:outline-none focus:ring-2 focus:ring-blue-500">
                </div>
                <div>
                    <label class="block text-sm font-semibold text-gray-700 mb-1">Alert Threshold</label>
                    <input type="number" name="seuilAlert" id="edit-seuilAlert" min="0"
                           class="w-full border border-gray-300 rounded-lg px-4 py-2.5 bg-gray-50
                                  focus:outline-none focus:ring-2 focus:ring-blue-500">
                </div>
            </div>

            <div>
                <label class="block text-sm font-semibold text-gray-700 mb-1">Description</label>
                <textarea name="description" id="edit-description" rows="2"
                          class="w-full border border-gray-300 rounded-lg px-4 py-2.5 bg-gray-50
