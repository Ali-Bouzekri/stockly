            </div>

            <div class="flex justify-end gap-3 pt-2 border-t">
                <button type="button" onclick="toggleEditModal(false)"
                        class="px-6 py-2.5 border rounded-lg text-gray-600 hover:bg-gray-50
                               font-semibold transition-colors">
                    Cancel
                </button>
                <button type="submit" id="editSubmitBtn"
                        class="px-6 py-2.5 bg-blue-600 text-white rounded-lg hover:bg-blue-700
                               font-semibold shadow transition-colors flex items-center gap-2">
                    <span>Update Product</span>
                    <svg class="hidden animate-spin h-4 w-4 text-white" id="editSubmitSpinner"
                         xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
                        <circle class="opacity-25" cx="12" cy="12" r="10"
                                stroke="currentColor" stroke-width="4"></circle>
                        <path class="opacity-75" fill="currentColor"
                              d="M4 12a8 8 0 018-8v8z"></path>
                    </svg>
                </button>
            </div>

        </form>
    </div>
</div>
{% endblock %}
{% block javascripts %}
<script>
// ─── Table filters (unchanged) ──────────────────────────────────────────────
document.addEventListener('DOMContentLoaded', () => {
    const catFilter    = document.getElementById('cat-filter');
    const subFilter    = document.getElementById('sub-cat-filter');
    const statusFilter = document.getElementById('status-filter');
    const searchInput  = document.getElementById('product-search');

    const rows = [...document.querySelectorAll('.product-item')].map(row => ({
        el:     row,
        cat:    (row.dataset.category    || '').trim().toLowerCase(),
        sub:    (row.dataset.subcategory || '').trim().toLowerCase(),
        status: (row.dataset.status      || '').toLowerCase(),
        text:   row.textContent.toLowerCase(),
    }));

    function applyFilters() {
        const cat    = catFilter.value.trim().toLowerCase();
        const sub    = subFilter.value.trim().toLowerCase();
        const status = statusFilter.value.toLowerCase();
        const search = searchInput.value.toLowerCase();

        rows.forEach(({ el, cat: rowCat, sub: rowSub, status: rowStatus, text }) => {
            const match = (cat    === 'all' || rowCat    === cat)
                       && (sub    === 'all' || rowSub    === sub)
                       && (status === 'all' || rowStatus === status)
                       && text.includes(search);

            el.style.display = match ? '' : 'none';
        });
    }

    catFilter.addEventListener('change', () => {
        const category = catFilter.value.toLowerCase();
        subFilter.value = 'all';
        document.querySelectorAll('.sub-option').forEach(opt => {
            const isMatch = category === 'all' || opt.dataset.parent.toLowerCase() === category;
            opt.style.display = isMatch ? '' : 'none';
            opt.disabled = !isMatch;
        });
        applyFilters();
    });

    subFilter.addEventListener('change', applyFilters);
    statusFilter.addEventListener('change', applyFilters);
    searchInput.addEventListener('input', applyFilters);

    // ✅ NEW: Apply filter from URL query parameter
    const urlParams = new URLSearchParams(window.location.search);
    const statusParam = urlParams.get('status');
    if (statusParam) {
        if (statusParam === 'low_stock') {
            statusFilter.value = 'low_stock';
        } else if (statusParam === 'out_of_stock') {
            statusFilter.value = 'out_of_stock';
        }
        // Manually call applyFilters to immediately filter the table
        applyFilters();
    }
});

// ─── Modal open / close ──────────────────────────────────────────────────────
function toggleModal(open) {
    const modal = document.getElementById('productModal');
    const isHidden = modal.classList.contains('hidden');

    if (open === false || !isHidden) {
        // Close
        modal.classList.add('hidden');
        document.body.style.overflow = 'auto';
        resetModalForm();
    } else {
        // Open
        modal.classList.remove('hidden');
        document.body.style.overflow = 'hidden';
    }
}

document.addEventListener('keydown', e => {
    if (e.key === 'Escape') {
        toggleModal(false);
        toggleEditModal(false);
    }
});

function resetModalForm() {
    document.getElementById('addProductForm').reset();
    document.getElementById('modal-subcategory').innerHTML =
        '<option value="">— Pick category first —</option>';
    document.getElementById('modal-subcategory').disabled = true;
    hideAlert();
}

// ─── Category → Subcategory dynamic filtering ────────────────────────────────
document.getElementById('modal-category').addEventListener('change', function () {
    const catId  = this.value;
    const subSel = document.getElementById('modal-subcategory');

    subSel.innerHTML = '<option value="">Loading…</option>';
    subSel.disabled  = true;

    if (!catId) {
        subSel.innerHTML = '<option value="">— Pick category first —</option>';
        return;
    }

    // Fetch matching subcategories from our JSON endpoint
    fetch(`/produit/api/subcategories/${catId}`)
        .then(r => r.json())
        .then(data => {
            if (data.length === 0) {
                subSel.innerHTML = '<option value="">No subcategories found</option>';
                return;
            }
            subSel.innerHTML = '<option value="">— Select —</option>';
            data.forEach(sub => {
                const opt = document.createElement('option');
                opt.value       = sub.id;
                opt.textContent = sub.name;
                subSel.appendChild(opt);
            });
            subSel.disabled = false;
        })
        .catch(() => {
            subSel.innerHTML = '<option value="">Error loading subcategories</option>';
        });
});

// ─── Form submission via fetch (no full page reload) ─────────────────────────
document.getElementById('addProductForm').addEventListener('submit', async function (e) {
    e.preventDefault();

    // ── Validation ──────────────────────────────────────────
    const designation  = document.getElementById('add-designation').value.trim();
    const category     = document.getElementById('modal-category').value;
    const subcategory  = document.getElementById('modal-subcategory').value;
    const unit         = this.querySelector('select[name="unite"]').value;

    if (!designation) {
        showAlert('Product name is required.', 'error');
        return;
    }
    if (!category) {
        showAlert('Please select a category.', 'error');
        return;
    }
    if (!subcategory) {
        showAlert('Please select a subcategory.', 'error');
        return;
    }
    if (!unit) {
        showAlert('Please select a unit.', 'error');
        return;}

    const btn     = document.getElementById('submitBtn');
    const spinner = document.getElementById('submitSpinner');
    const btnText = document.getElementById('submitBtnText');

    btn.disabled    = true;
    spinner.classList.remove('hidden');
    btnText.textContent = 'Saving…';
    hideAlert();

    try {
        const res = await fetch('{{ path("app_produit_new") }}', {
            method:  'POST',
            headers: { 'X-Requested-With': 'XMLHttpRequest' },
            body:    new FormData(this),
        });

        const json = await res.json();

        if (json.success) {
            showAlert('✅ Product saved successfully!', 'success');
            this.reset();
            document.getElementById('modal-subcategory').innerHTML =
                '<option value="">— Pick category first —</option>';
            document.getElementById('modal-subcategory').disabled = true;

            // Reload the page after a short delay so the table updates
            setTimeout(() => window.location.reload(), 900);
        } else {
            showAlert(json.error || 'Something went wrong. Please try again.', 'error');
        }
    } catch {
        showAlert('Network error. Please check your connection.', 'error');
    } finally {
        btn.disabled        = false;
        spinner.classList.add('hidden');
        btnText.textContent = 'Save Product';
    }
});

// ─── Alert helpers ───────────────────────────────────────────────────────────
function showAlert(message, type) {
    const el = document.getElementById('modal-alert');
    el.textContent = message;
    el.className = type === 'success'
        ? 'mx-8 mt-4 px-4 py-3 rounded-lg text-sm font-semibold bg-green-100 text-green-700'
        : 'mx-8 mt-4 px-4 py-3 rounded-lg text-sm font-semibold bg-red-100 text-red-700';
}

function hideAlert() {
    document.getElementById('modal-alert').className = 'hidden';
}
function toggleEditModal(open) {
    const modal = document.getElementById('editProductModal');
    const isHidden = modal.classList.contains('hidden');

    if (open === false || !isHidden) {
        modal.classList.add('hidden');
        document.body.style.overflow = 'auto';
        document.getElementById('editProductForm').reset();
        hideEditAlert();
    } else {
        modal.classList.remove('hidden');
        document.body.style.overflow = 'hidden';
    }
}

function openEditModal(el) {
    const d = el.dataset;
    toggleEditModal(true);

    document.getElementById('edit-idProduit').value    = d.id;
    document.getElementById('edit-designation').value  = d.designation;
    document.getElementById('edit-qteStock').value     = d.stock;
    document.getElementById('edit-seuilAlert').value   = d.seuil;
    document.getElementById('edit-description').value  = d.description || '';
    document.getElementById('edit-unite').value        = d.uniteId;

    // Set category then populate subcategory
    const catSel = document.getElementById('edit-category');
    catSel.value = d.catId;

    const subSel = document.getElementById('edit-subcategory');
    if (d.catId) {
        fetch(`/produit/api/subcategories/${d.catId}`)
            .then(r => r.json())
            .then(subs => {
                subSel.innerHTML = '<option value="">— Select —</option>';
                subs.forEach(sub => {
                    const opt = document.createElement('option');
                    opt.value = sub.id;
                    opt.textContent = sub.name;
                    if (sub.id == d.subId) opt.selected = true;
                    subSel.appendChild(opt);
                });
                subSel.disabled = false;
            });
    }
}

// Optional alert functions
function showEditAlert(message, type) {
    const el = document.getElementById('edit-modal-alert');
    el.textContent = message;
    el.className = type === 'success'
        ? 'mx-8 mt-4 px-4 py-3 rounded-lg text-sm font-semibold bg-green-100 text-green-700'
        : 'mx-8 mt-4 px-4 py-3 rounded-lg text-sm font-semibold bg-red-100 text-red-700';
}
function hideEditAlert() {
    document.getElementById('edit-modal-alert').className = 'hidden';
}
// --- Edit Form submission via fetch ---
document.getElementById('editProductForm').addEventListener('submit', async function (e) {
    e.preventDefault();

    const btn = document.getElementById('editSubmitBtn');
    const spinner = document.getElementById('editSubmitSpinner');
    const id = document.getElementById('edit-idProduit').value;

    if (!id) {
        showEditAlert("Missing Product ID", "error");
        return;
    }

    btn.disabled = true;
    spinner.classList.remove('hidden');

    try {
        // We use a relative path to avoid "localhost" vs "127.0.0.1" issues
        const res = await fetch(`/produit/edit/${id}`, {
            method: 'POST',
            headers: { 'X-Requested-With': 'XMLHttpRequest' },
            body: new FormData(this),
        });

        if (res.ok) {
            const json = await res.json();
            if (json.success) {
                showEditAlert('✅ Updated! Reloading...', 'success');
                setTimeout(() => window.location.reload(), 800);
            } else {
                showEditAlert(json.error || 'Save failed', 'error');
            }
        } else {
            showEditAlert(`Server Error: ${res.status}`, 'error');
        }
    } catch (err) {
        showEditAlert('Connection failed. Is the server running?', 'error');
    } finally {
        btn.disabled = false;
        spinner.classList.add('hidden');
    }
});
document.getElementById('edit-category').addEventListener('change', function () {
    const catId = this.value;
    const subSel = document.getElementById('edit-subcategory');
    subSel.innerHTML = '<option value="">Loading…</option>';
    subSel.disabled = true;

    if (!catId) {
        subSel.innerHTML = '<option value="">— Pick category first —</option>';
        return;
    }

    fetch(`/produit/api/subcategories/${catId}`)
        .then(r => r.json())
        .then(data => {
            subSel.innerHTML = '<option value="">— Select —</option>';
            data.forEach(sub => {
                const opt = document.createElement('option');
                opt.value = sub.id;
                opt.textContent = sub.name;
                subSel.appendChild(opt);
            });
            subSel.disabled = false;
        });
});
async function deleteProduct(id, token) {
    if (!confirm('Delete this product?')) return;

    const res = await fetch(`/produit/${id}/delete`, {
        method: 'POST',
        headers: { 'X-Requested-With': 'XMLHttpRequest' },
        body: new URLSearchParams({ _token: token }),
    });

    const json = await res.json();
    if (json.success) {
        // Remove the row from the DOM — no reload needed
        document.querySelector(`tr[data-id="${id}"]`)?.remove();
    } else {
        alert('Delete failed.');
    }
}
function exportToPDF() {
    // Collect only the currently visible rows (respects all active filters)
    const visibleRows = [...document.querySelectorAll('.product-item')]
        .filter(row => row.style.display !== 'none');

    if (visibleRows.length === 0) {
        alert('No products to export with the current filters.');
        return;
    }

    // Build a self-contained print HTML page
    const rows = visibleRows.map(row => {
        const cells = row.querySelectorAll('td');
        const name     = cells[0]?.innerText.trim() ?? '—';
        const category = cells[1]?.innerText.trim() ?? '—';
        const stock    = cells[2]?.querySelector('span')?.innerText.trim() ?? '—';
        const unit     = cells[3]?.innerText.trim() ?? '—';
        const status   = cells[4]?.innerText.trim() ?? '—';

        // Status badge colour
        let badgeStyle = 'background:#f3f4f6;color:#6b7280';
        if (status.includes('In Stock'))     badgeStyle = 'background:#dcfce7;color:#15803d';
        if (status.includes('Low Stock'))    badgeStyle = 'background:#ffedd5;color:#c2410c';
        if (status.includes('Out of Stock')) badgeStyle = 'background:#f3f4f6;color:#6b7280';

        return `
        <tr>
            <td style="padding:10px 14px;font-weight:600;color:#1f2937;">${name}</td>
            <td style="padding:10px 14px;color:#6b7280;">${category}</td>
            <td style="padding:10px 14px;font-weight:700;color:#111827;">${stock}</td>
            <td style="padding:10px 14px;color:#9ca3af;font-size:12px;">${unit}</td>
            <td style="padding:10px 14px;">
                <span style="padding:3px 10px;border-radius:9999px;font-size:11px;font-weight:700;${badgeStyle}">
                    ${status}
                </span>
            </td>
        </tr>`;
    }).join('');

    const now = new Date().toLocaleDateString('fr-MA', {
        day: '2-digit', month: 'long', year: 'numeric'
    });

    const html = `<!DOCTYPE html>
<html>
<head>
<meta charset="UTF-8">
<title>Products Inventory — Bouzekri Solutions</title>
<style>
  * { margin: 0; padding: 0; box-sizing: border-box; }
  body { font-family: 'Segoe UI', Arial, sans-serif; background: #fff; padding: 32px; color: #111; }
  .header { display: flex; justify-content: space-between; align-items: flex-end; margin-bottom: 24px; border-bottom: 2px solid #2563eb; padding-bottom: 16px; }
  .brand { font-size: 22px; font-weight: 800; color: #2563eb; }
  .meta  { font-size: 12px; color: #6b7280; text-align: right; }
  h1 { font-size: 18px; font-weight: 700; color: #1f2937; margin-bottom: 4px; }
  p  { font-size: 12px; color: #6b7280; margin-bottom: 24px; }
  table { width: 100%; border-collapse: collapse; }
  thead tr { background: #f9fafb; border-bottom: 2px solid #e5e7eb; }
  thead th { padding: 10px 14px; font-size: 12px; font-weight: 700; color: #6b7280; text-align: left; }
  tbody tr { border-bottom: 1px solid #f3f4f6; }
  tbody tr:last-child { border-bottom: none; }
  .footer { margin-top: 32px; font-size: 11px; color: #9ca3af; text-align: center; border-top: 1px solid #e5e7eb; padding-top: 12px; }
  @media print { body { padding: 16px; } }
</style>
</head>
<body>
<div class="header">
  <div class="brand">Bouzekri Solutions</div>
  <div class="meta">Generated: ${now}<br>Total: ${visibleRows.length} product(s)</div>
</div>
<h1>Products Inventory</h1>
<p>Exported with current filters applied</p>
<table>
  <thead>
    <tr>
      <th>Product Name</th>
      <th>Category</th>
      <th>Stock</th>
      <th>Unit</th>
      <th>Status</th>
    </tr>
  </thead>
  <tbody>${rows}</tbody>
</table>
<div class="footer">Bouzekri Solutions — Internal Document — ${now}</div>
<script>window.onload = () => { window.print(); }<\/script>
</body>
</html>`;

    const win = window.open('', '_blank');
    win.document.write(html);
    win.document.close();
}
// Read URL query parameters and apply filters
const urlParams = new URLSearchParams(window.location.search);
const statusParam = urlParams.get('status');

if (statusParam) {
    const statusFilter = document.getElementById('status-filter');
    if (statusFilter) {
        if (statusParam === 'low_stock') {
            statusFilter.value = 'low_stock';
        } else if (statusParam === 'out_of_stock') {
            statusFilter.value = 'out_of_stock';
        }
        // Trigger the filter update (calls the existing applyFilters function)
        statusFilter.dispatchEvent(new Event('change'));
    }
}
</script>
{% endblock %}


