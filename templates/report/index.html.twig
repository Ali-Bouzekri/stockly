{% extends 'base.html.twig' %}
{% block title %}Reports - Bouzekri Solutions{% endblock %}

{% block body %}
<div class="flex h-screen bg-gray-100">
<main class="flex-1 overflow-auto">
<div class="px-8 pt-8 pb-12">

    <header class="flex justify-end items-center mb-8">
        <div class="flex gap-6 items-center">
            <span class="text-xl cursor-pointer">🔔</span>
            <div class="w-10 h-10 bg-gray-300 rounded-full flex items-center justify-center text-white font-bold cursor-pointer">👤</div>
        </div>
    </header>

    <div class="flex justify-between items-end mb-8">
        <div>
            <h1 class="text-2xl font-bold text-gray-800">Reports</h1>
            <p class="text-gray-500 mt-1">Overview of stock and order activity</p>
        </div>
        <button onclick="window.print()"
                class="border border-gray-300 rounded-lg py-2 px-4 text-gray-700 hover:bg-gray-50 flex items-center gap-2 font-medium transition-colors">
            🖨️ Print Report
        </button>
    </div>

    {# ── Stock summary cards ── #}
    <div class="grid grid-cols-4 gap-5 mb-8">
        <div class="bg-white rounded-xl border shadow-sm p-5 border-b-4 border-blue-500">
            <p class="text-sm text-gray-500 mb-1">Total Products</p>
            <p class="text-3xl font-bold text-gray-800">{{ totalProduits }}</p>
            <p class="text-xs text-blue-600 font-semibold mt-1">In System</p>
        </div>
        <div class="bg-white rounded-xl border shadow-sm p-5 border-b-4 border-green-500">
            <p class="text-sm text-gray-500 mb-1">In Stock</p>
            <p class="text-3xl font-bold text-gray-800">{{ inStock }}</p>
            <p class="text-xs text-green-600 font-semibold mt-1">Healthy Level</p>
        </div>
        <div class="bg-white rounded-xl border shadow-sm p-5 border-b-4 border-orange-500">
            <p class="text-sm text-gray-500 mb-1">Low Stock</p>
            <p class="text-3xl font-bold text-gray-800">{{ lowStock }}</p>
            <p class="text-xs text-orange-600 font-semibold mt-1">Require Attention</p>
        </div>
        <div class="bg-white rounded-xl border shadow-sm p-5 border-b-4 border-red-500">
            <p class="text-sm text-gray-500 mb-1">Out of Stock</p>
            <p class="text-3xl font-bold text-gray-800">{{ outStock }}</p>
            <p class="text-xs text-red-600 font-semibold mt-1">Needs Restocking</p>
        </div>
    </div>

    {# ── Orders summary ── #}
    <div class="grid grid-cols-2 gap-6 mb-8">

        {# Internal Orders #}
        <div class="bg-white rounded-xl border shadow-sm p-6">
            <div class="flex justify-between items-center mb-4">
                <h2 class="font-bold text-gray-700">Internal Orders</h2>
                <span class="text-2xl font-bold text-blue-600">{{ totalIntern }}</span>
            </div>
            {% if internByStatus is empty %}
                <p class="text-sm text-gray-400 text-center py-4">No orders yet.</p>
            {% else %}
                <div class="space-y-2">
                    {% set internColors = {
                        'En attente':               'bg-yellow-100 text-yellow-700',
                        'Approuvée':                'bg-blue-100 text-blue-700',
                        'En cours de préparation':  'bg-purple-100 text-purple-700',
                        'Prête':                    'bg-green-100 text-green-700',
                        'Livrée':                   'bg-gray-100 text-gray-600',
                        'Rejetée':                  'bg-red-100 text-red-700',
                    } %}
                    {% for status, count in internByStatus %}
                        <div class="flex items-center justify-between py-2 border-b last:border-0">
                            <span class="px-2 py-0.5 rounded-full text-xs font-bold {{ internColors[status] ?? 'bg-gray-100 text-gray-600' }}">
                                {{ status }}
                            </span>
                            <span class="font-bold text-gray-700">{{ count }}</span>
                        </div>
                    {% endfor %}
                </div>
            {% endif %}
            <a href="{{ path('app_cmd_intern_index') }}"
               class="mt-4 block text-center text-sm text-blue-600 hover:underline font-semibold">
                View All →
            </a>
        </div>

        {# External Orders #}
        <div class="bg-white rounded-xl border shadow-sm p-6">
            <div class="flex justify-between items-center mb-4">
                <h2 class="font-bold text-gray-700">External Orders</h2>
                <span class="text-2xl font-bold text-blue-600">{{ totalExtern }}</span>
            </div>
            {% if externByStatus is empty %}
                <p class="text-sm text-gray-400 text-center py-4">No orders yet.</p>
            {% else %}
                <div class="space-y-2">
                    {% set externColors = {
                        'Brouillon':                    'bg-gray-100 text-gray-600',
                        'Commandée':                    'bg-blue-100 text-blue-700',
                        'Expédiée':                     'bg-purple-100 text-purple-700',
                        'Réceptionnée Partiellement':   'bg-yellow-100 text-yellow-700',
                        'Réceptionnée':                 'bg-green-100 text-green-700',
                        'Annulée':                      'bg-red-100 text-red-700',
                    } %}
                    {% for status, count in externByStatus %}
                        <div class="flex items-center justify-between py-2 border-b last:border-0">
                            <span class="px-2 py-0.5 rounded-full text-xs font-bold {{ externColors[status] ?? 'bg-gray-100 text-gray-600' }}">
                                {{ status }}
                            </span>
                            <span class="font-bold text-gray-700">{{ count }}</span>
                        </div>
                    {% endfor %}
                </div>
            {% endif %}
            <a href="{{ path('app_cmd_extern_index') }}"
               class="mt-4 block text-center text-sm text-blue-600 hover:underline font-semibold">
                View All →
            </a>
        </div>

    </div>
{# ── Recent orders tables ── #}
    <div class="grid grid-cols-2 gap-6 mb-8">

        <div class="bg-white rounded-xl border shadow-sm p-6">
            <h2 class="font-bold text-gray-700 mb-4">Recent Internal Orders</h2>
            {% if recentIntern is empty %}
                <p class="text-sm text-gray-400 text-center py-4">No orders found.</p>
            {% else %}
                <div class="space-y-3">
                    {% for o in recentIntern %}
                        <div class="flex items-center justify-between border-b last:border-0 pb-3 last:pb-0">
                            <div>
                                <p class="font-semibold text-gray-800 text-sm">
                                    #{{ o.numero }} —
                                    {% if o.fonctionnaire %}{{ o.fonctionnaire.prenom }} {{ o.fonctionnaire.nom }}{% else %}Unknown{% endif %}
                                </p>
                                <p class="text-xs text-gray-400">{{ o.dateCI ? o.dateCI|date('d/m/Y') : '—' }}</p>
                            </div>
                            <span class="px-2 py-0.5 rounded-full text-xs font-bold
                                {% if o.statut == 'Livrée' %} bg-green-100 text-green-700
                                {% elseif o.statut == 'Rejetée' %} bg-red-100 text-red-700
                                {% elseif o.statut == 'En attente' %} bg-yellow-100 text-yellow-700
                                {% else %} bg-blue-100 text-blue-700 {% endif %}">
                                {{ o.statut }}
                            </span>
                        </div>
                    {% endfor %}
                </div>
            {% endif %}
        </div>

        <div class="bg-white rounded-xl border shadow-sm p-6">
            <h2 class="font-bold text-gray-700 mb-4">Recent External Orders</h2>
            {% if recentExtern is empty %}
                <p class="text-sm text-gray-400 text-center py-4">No orders found.</p>
            {% else %}
                <div class="space-y-3">
                    {% for o in recentExtern %}
                        <div class="flex items-center justify-between border-b last:border-0 pb-3 last:pb-0">
                            <div>
                                <p class="font-semibold text-gray-800 text-sm">
                                    #{{ o.numero }} —
                                    {% if o.fournisseur %}{{ o.fournisseur.denominateur }}{% else %}Unknown{% endif %}
                                </p>
                                <p class="text-xs text-gray-400">{{ o.dateCE ? o.dateCE|date('d/m/Y') : '—' }}</p>
                            </div>
                            <span class="px-2 py-0.5 rounded-full text-xs font-bold
                                {% if o.statut == 'Réceptionnée' %} bg-green-100 text-green-700
                                {% elseif o.statut == 'Annulée' %} bg-red-100 text-red-700
                                {% elseif o.statut == 'Brouillon' %} bg-gray-100 text-gray-600
                                {% else %} bg-blue-100 text-blue-700 {% endif %}">
                                {{ o.statut }}
                            </span>
                        </div>
                    {% endfor %}
                </div>
            {% endif %}
        </div>

    </div>
    {# ── Low stock table ── #}
    <div class="bg-white rounded-xl border shadow-sm p-6 mb-8">
        <h2 class="font-bold text-gray-700 mb-4">⚠️ Low Stock & Out of Stock Products</h2>
        {% if lowStockProducts is empty %}
            <p class="text-sm text-gray-400 text-center py-4">All products are sufficiently stocked. 🎉</p>
        {% else %}
            <div class="overflow-x-auto">
                <table class="w-full text-sm text-left">
                    <thead>
                        <tr class="border-b text-gray-500">
                            <th class="pb-3 font-semibold">Product</th>
                            <th class="pb-3 font-semibold">Category</th>
                            <th class="pb-3 font-semibold">Stock</th>
                            <th class="pb-3 font-semibold">Threshold</th>
                            <th class="pb-3 font-semibold">Status</th>
                        </tr>
                    </thead>
                    <tbody class="divide-y divide-gray-100">
                        {% for p in lowStockProducts %}
                            <tr>
                                <td class="py-3 font-semibold text-gray-800">{{ p.designation }}</td>
                                <td class="py-3 text-gray-500">{{ p.sousCategorie ? p.sousCategorie.nomSousCat : '—' }}</td>
                                <td class="py-3 font-bold {{ p.qteStock == 0 ? 'text-red-600' : 'text-orange-600' }}">
                                    {{ p.qteStock }}
                                </td>
                                <td class="py-3 text-gray-500">{{ p.seuilAlert }}</td>
                                <td class="py-3">
                                    {% if p.qteStock == 0 %}
                                        <span class="px-2 py-0.5 rounded-full text-xs font-bold bg-gray-100 text-gray-600">Out of Stock</span>
                                    {% else %}
                                        <span class="px-2 py-0.5 rounded-full text-xs font-bold bg-orange-100 text-orange-700">Low Stock</span>
                                    {% endif %}
                                </td>
                            </tr>
                        {% endfor %}
                    </tbody>
                </table>
            </div>
        {% endif %}
    </div>

    

</div>
</main>
</div>

<style>
@media print {
    aside, header, button { display: none !important; }
    main { overflow: visible !important; }
    .grid { break-inside: avoid; }
}
</style>
{% endblock %}
