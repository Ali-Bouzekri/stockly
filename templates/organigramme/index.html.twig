{% extends 'base.html.twig' %}

{% block title %}Organigramme index{% endblock %}

{% block body %}
    <h1>Organigramme index</h1>

    <table class="table">
        <thead>
            <tr>
                <th>IdOrg</th>
                <th>Departement</th>
                <th>actions</th>
            </tr>
        </thead>
        <tbody>
        {% for organigramme in organigrammes %}
            <tr>
                <td>{{ organigramme.idOrg }}</td>
                <td>{{ organigramme.departement }}</td>
                <td>
                    <a href="{{ path('app_organigramme_show', {'idOrg': organigramme.idOrg}) }}">show</a>
                    <a href="{{ path('app_organigramme_edit', {'idOrg': organigramme.idOrg}) }}">edit</a>
                </td>
            </tr>
        {% else %}
            <tr>
                <td colspan="3">no records found</td>
            </tr>
        {% endfor %}
        </tbody>
    </table>

    <a href="{{ path('app_organigramme_new') }}">Create new</a>
{% endblock %}
