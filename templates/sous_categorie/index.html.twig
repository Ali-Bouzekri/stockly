{% extends 'base.html.twig' %}

{% block title %}SousCategorie index{% endblock %}

{% block body %}
    <h1>SousCategorie index</h1>

    <table class="table">
        <thead>
            <tr>
                <th>IdSousCat</th>
                <th>NomSousCat</th>
                <th>actions</th>
            </tr>
        </thead>
        <tbody>
        {% for sous_categorie in sous_categories %}
            <tr>
                <td>{{ sous_categorie.idSousCat }}</td>
                <td>{{ sous_categorie.nomSousCat }}</td>
                <td>
                    <a href="{{ path('app_sous_categorie_show', {'idSousCat': sous_categorie.idSousCat}) }}">show</a>
                    <a href="{{ path('app_sous_categorie_edit', {'idSousCat': sous_categorie.idSousCat}) }}">edit</a>
                </td>
            </tr>
        {% else %}
            <tr>
                <td colspan="3">no records found</td>
            </tr>
        {% endfor %}
        </tbody>
    </table>

    <a href="{{ path('app_sous_categorie_new') }}">Create new</a>
{% endblock %}
