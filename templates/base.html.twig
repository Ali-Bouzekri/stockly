<!DOCTYPE html>
<html>
<head>
    <meta charset="UTF-8">
    <title>{% block title %}Stockly{% endblock %}</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <script src="https://cdn.tailwindcss.com"></script>
    {% block stylesheets %}{% endblock %}
</head>
<body class="bg-gray-100">
<div class="flex h-screen bg-gray-100">

    {# ===== Sidebar ===== #}
    <aside class="w-64 bg-white border-r flex flex-col flex-shrink-0">
        <div class="p-6 font-bold text-xl text-blue-600">Stockly</div>

        <nav class="mt-2 flex-1 flex flex-col">

            {# ── Main navigation ── #}
            <a href="{{ path('app_dashboard') }}"
               class="flex items-center gap-3 px-6 py-2.5 text-base font-large
                      {{ app.request.get('_route') == 'app_dashboard'
                         ? 'bg-blue-50 text-blue-700 border-r-2 border-blue-600'
                         : 'text-gray-600 hover:bg-gray-50' }}">
                🏠 Dashboard
            </a>

            <a href="{{ path('app_produit_index') }}"
               class="flex items-center gap-3 px-6 py-2.5 text-base font-medium
                      {{ app.request.get('_route') starts with 'app_produit'
                         ? 'bg-blue-50 text-blue-700 border-r-2 border-blue-600'
                         : 'text-gray-600 hover:bg-gray-50' }}">
                📦 Products Inventory
            </a>

            {# ── Orders section ── #}
            <p class="px-6 pt-5 pb-1 text-xs font-bold text-gray-400 uppercase tracking-wider">Orders</p>

            <a href="{{ path('app_cmd_intern_index') }}"
               class="flex items-center gap-3 px-6 py-2.5 text-base font-medium
                      {{ app.request.get('_route') starts with 'app_cmd_intern'
                         ? 'bg-blue-50 text-blue-700 border-r-2 border-blue-600'
                         : 'text-gray-600 hover:bg-gray-50' }}">
                🏭 Internal Orders
            </a>

            <a href="{{ path('app_cmd_extern_index') }}"
               class="flex items-center gap-3 px-6 py-2.5 text-base font-medium
                      {{ app.request.get('_route') starts with 'app_cmd_extern'
                         ? 'bg-blue-50 text-blue-700 border-r-2 border-blue-600'
                         : 'text-gray-600 hover:bg-gray-50' }}">
                🚚 External Orders
            </a>

            {# ── Analytics section ── #}
            <p class="px-6 pt-5 pb-1 text-xs font-bold text-gray-400 uppercase tracking-wider">Analytics</p>

            <a href="{{ path('app_report_index') }}"
               class="flex items-center gap-3 px-6 py-2.5 text-base font-medium
                      {{ app.request.get('_route') starts with 'app_report'
                         ? 'bg-blue-50 text-blue-700 border-r-2 border-blue-600'
                         : 'text-gray-600 hover:bg-gray-50' }}">
                📊 Reports
            </a>

            {# ── Bottom spacer + settings ── #}
            <div class="flex-1"></div>
            <a href="{{ path('app_logout') }}" class="flex items-center gap-3 px-6 py-4 text-base font-medium text-gray-500 hover:bg-gray-50 border-t">
                🚪 Logout
            </a>
        </nav>
    </aside>

    {# ===== Main content area ===== #}
    <main class="flex-1 overflow-auto">
        {# Top bar with notifications and user avatar #}
        <div class="sticky top-0 z-30 bg-gray-100 px-8 pt-4 pb-2 flex justify-end items-center gap-4 border-b border-gray-200">
            {# Notification Bell #}
            <a href="{{ path('app_notifications') }}" class="relative">
                <span class="text-xl">🔔</span>
                {% set unreadCount = app.user ? notificationRepo.findUnreadByUser(app.user)|length : 0 %}
                {% if unreadCount > 0 %}
                    <span class="absolute -top-2 -right-2 bg-red-500 text-white text-xs rounded-full w-5 h-5 flex items-center justify-center font-bold">
                        {{ unreadCount }}
                    </span>
                {% endif %}
            </a>
            {# User Avatar #}
            <div class="w-10 h-10 bg-blue-600 rounded-full flex items-center justify-center text-white font-bold cursor-pointer">
                {{ app.user ? app.user.prenom|first|upper ~ app.user.nom|first|upper : '👤' }}
            </div>
        </div>

        {# Page content #}
        <div class="p-6">
            {% block body %}{% endblock %}
        </div>
    </main>

</div>
{% if is_granted('ROLE_WAREHOUSE') %}
    <a href="{{ path('app_cmd_extern_index') }}" class="...">🚚 External Orders</a>
{% endif %}
{% block javascripts %}{% endblock %}
</body>
</html>