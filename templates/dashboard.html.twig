
{% extends 'base.html.twig' %}

{% block title %}Dashboard - Bouzekri Solutions{% endblock %}

{% block body %}
<div class="flex h-screen bg-gray-100">
    <aside class="w-64 bg-white border-r">
        <div class="p-6 font-bold text-xl text-blue-600"></div>
        <nav class="mt-4">
            <a href="{{ path('app_dashboard') }}" class="block px-6 py-2 bg-blue-50 text-blue-600 border-l-4 border-blue-600">Dashboard</a>
            <a href="#" class="block px-6 py-2 text-gray-600 hover:bg-gray-50 italic">Inventory ⌵</a>
            <a href="#" class="block px-6 py-2 text-gray-600 hover:bg-gray-50 italic">Internal Operations ⌵</a>
            <a href="#" class="block px-6 py-2 text-gray-600 hover:bg-gray-50 italic">Suppliers ⌵</a>
            <a href="#" class="block px-6 py-2 text-gray-600 hover:bg-gray-50 italic">Organisation ⌵</a>
            <a href="#" class="block px-6 py-2 text-gray-600 hover:bg-gray-50 italic">Reports ⌵</a>
            <a href="#" class="block px-6 py-2 mt-10 text-gray-400 hover:bg-gray-50">⚙️ Settings</a>
        </nav>
    </aside>

    <main class="flex-1 p-8 overflow-y-auto">
        <header class="flex justify-between items-center mb-8">
            <div class="relative w-1/3">
                <span class="absolute inset-y-0 left-0 pl-3 flex items-center text-gray-400">🔍</span>

<input type="text" placeholder="Search products or orders..." class="border py-2 pr-3 pl-10 rounded w-full focus:outline-none focus:ring-2 focus:ring-blue-500">

            </div>
            <div class="flex gap-6 items-center">
                <span class="text-xl cursor-pointer">🔔</span>
                <div class="w-10 h-10 bg-gray-300 rounded-full flex items-center justify-center text-white font-bold cursor-pointer">👤</div>
            </div>
        </header>

        <h1 class="text-2xl font-bold">Dashboard</h1>
        <p class="text-gray-500 mb-8 font-serif">Welcome back, here's your stock management overview</p>

        <div class="grid grid-cols-4 gap-4 mb-8">
            <div class="bg-white p-4 rounded shadow border-b-4 border-blue-500">
                <div class="flex justify-between items-start">
                    <p class="text-sm text-gray-500">Total Products</p>
                    <span>📦</span>
                </div>
                <p class="text-2xl font-bold mt-1">{{ totalProducts }}</p>
                <p class="text-xs text-green-500 mt-2">In System</p>
            </div>

            <div class="bg-white p-4 rounded shadow border-b-4 border-orange-500">
                <div class="flex justify-between items-start">
                    <p class="text-sm text-gray-500">Low Stock Items</p>
                    <span>⚠️</span>
                </div>
                <p class="text-2xl font-bold mt-1">{{ lowStockItems }}</p>
                <p class="text-xs text-orange-500 mt-2 font-semibold">Require Attention</p>
            </div>

            <div class="bg-white p-4 rounded shadow border-b-4 border-yellow-500">
                <div class="flex justify-between items-start">
                    <p class="text-sm text-gray-500">Pending Orders</p>
                    <span>🕒</span>
                </div>
                <p class="text-2xl font-bold mt-1">{{ pendingOrders }}</p>
                <p class="text-xs text-yellow-600 mt-2">Awaiting Processing</p>
            </div>

            <div class="bg-white p-4 rounded shadow border-b-4 border-green-500">
                <div class="flex justify-between items-start">
                    <p class="text-sm text-gray-500">Total Inventory Value</p>
                    <span>💰</span>
                </div>
                <p class="text-2xl font-bold mt-1">${{ totalValue|number_format(2, '.', ',') }}</p>
                <p class="text-xs text-gray-400 mt-2">Current Value</p>
            </div>
        </div>

        <div class="flex gap-4 mb-8">
            <button class="bg-white border hover:bg-gray-50 p-4 rounded-lg shadow-sm flex-1 text-center font-semibold transition-all">
                <span class="text-blue-600 mr-2">+</span> New Internal Order
            </button>
            <button class="bg-white border hover:bg-gray-50 p-4 rounded-lg shadow-sm flex-1 text-center font-semibold transition-all">
                <span class="text-blue-600 mr-2">+</span> New External Order
            </button>
            <button class="bg-white border hover:bg-gray-100 p-4 rounded-lg shadow-sm flex-1 text-center font-semibold transition-all">
                View Reports →
            </button>
        </div>

        <div class="grid grid-cols-2 gap-8">
            <div class="bg-white p-6 rounded-xl shadow">
                <h2 class="font-bold text-lg mb-4 flex items-center">
                    <span class="text-red-500 mr-2">⚠️</span> Low Stock Alerts
                </h2>
                <div class="space-y-1">
                    {% for item in lowStockAlerts %}
                        <div class="flex justify-between items-center border-b py-3 last:border-0">
                            <div>
                                <p class="font-bold text-gray-800">{{ item.nom }}</p>
                                <p class="text-xs text-gray-400">Stock: {{ item.qteStock }}</p>
                            </div>
                            <span class="text-sm font-semibold text-red-600 bg-red-50 px-3 py-1 rounded-full">
                                {{ item.seuilAlert }} (Seuil)
                            </span>
                        </div>
                    {% else %}
                        <p class="text-gray-400 text-center py-4">No critical stock levels found.</p>
                    {% endfor %}
                </div>
                <button class="w-full mt-4 text-sm text-blue-600 font-bold hover:underline">View All Alerts</button>
            </div>

            <div class="bg-white p-6 rounded-xl shadow">
                <h2 class="font-bold text-lg mb-4">Recent Orders</h2>
                <div class="space-y-1">
                    {% for order in recentOrders %}
                        <div class="flex justify-between items-center border-b py-3 last:border-0">
                            <div>
                                <p class="font-bold text-gray-800">ORD-{{ order.idCmdInt }}</p>
                                <p class="text-xs text-gray-400">{{ order.dateCI|date('d/m/Y') }} • Internal</p>
                            </div>
                            <span class="px-3 py-1 rounded-full text-xs font-bold uppercase
                                {% if order.statut == 'En attente' %} bg-yellow-100 text-yellow-700 
                                {% elseif order.statut == 'Livrée' %} bg-green-100 text-green-700
                                {% elseif order.statut == 'Rejetée' %} bg-red-100 text-red-700
                                {% else %} bg-blue-100 text-blue-700 {% endif %}">
                                {{ order.statut }}
                            </span>
                        </div>
                    {% else %}
                        <p class="text-gray-400 text-center py-4 text-sm">No recent orders found.</p>
                    {% endfor %}
                </div>
                <button class="w-full mt-4 text-sm text-blue-600 font-bold hover:underline">View All Orders</button>
            </div>
        </div>
    </main>
</div>
{% endblock %}