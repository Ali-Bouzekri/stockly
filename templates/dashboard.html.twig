{% extends 'base.html.twig' %}

{% block title %}Stockly - Dashboard{% endblock %}

{% block body %}
<div class="flex h-screen bg-gray-100 overflow-hidden">
    <main class="flex-1 p-8 flex flex-col overflow-hidden">

        <!--<header class="flex justify-between items-center mb-6 flex-shrink-0">
             
            <div class="relative w-1/3">
                <span class="absolute inset-y-0 left-0 pl-3 flex items-center text-gray-400">🔍</span>
                <input type="text" placeholder="Search products or orders..."
                       class="border py-2 pr-3 pl-10 rounded w-full focus:outline-none focus:ring-2 focus:ring-blue-500">
            </div>
            <div class="flex gap-6 items-center">
                <span class="text-xl cursor-pointer">🔔</span>
                <div class="w-10 h-10 bg-gray-300 rounded-full flex items-center justify-center text-white font-bold cursor-pointer">👤</div>
            </div>
        </header>-->

        <h1 class="text-2xl font-bold flex-shrink-0">Dashboard</h1>
        <p class="text-gray-500 mb-6 font-serif flex-shrink-0">Welcome back, here's your stock management overview</p>

        {# ── Stat Cards ── #}
<div class="grid grid-cols-4 gap-4 mb-6 flex-shrink-0">

    {# Total Products #}
    <a href="{{ path('app_produit_index') }}" class="block transition hover:shadow-lg">
        <div class="bg-white p-5 rounded-xl shadow border-b-4 border-blue-500 h-full">
            <div class="flex justify-between items-start">
                <p class="text-sm font-medium text-gray-500">Total Products</p>
                <span>📦</span>
            </div>
            <p class="text-3xl font-bold mt-2">{{ totalProducts }}</p>
            <p class="text-sm text-green-500 mt-2 font-semibold">In System</p>
        </div>
    </a>

    {# Low Stock Items #}
    <a href="{{ path('app_produit_index', {status: 'low_stock'}) }}" class="block transition hover:shadow-lg">
        <div class="bg-white p-5 rounded-xl shadow border-b-4 border-orange-500 h-full">
            <div class="flex justify-between items-start">
                <p class="text-sm font-medium text-gray-500">Low Stock Items</p>
                <span>⚠️</span>
            </div>
            <p class="text-3xl font-bold mt-2">{{ lowStockItems }}</p>
            <p class="text-sm text-orange-500 mt-2 font-semibold">Require Attention</p>
        </div>
    </a>

    {# Pending Orders #}
    <div class="bg-white p-5 rounded-xl shadow border-b-4 border-yellow-500 h-full">
    <div class="flex justify-between items-start">
        <p class="text-sm font-medium text-gray-500">Pending Orders</p>
        <span>🕒</span>
    </div>
    <p class="text-4xl font-bold mt-2">{{ pendingIntern + pendingExtern }}</p>
    <p class="text-sm text-yellow-600 mt-2">
        🏭
        <a href="{{ path('app_cmd_intern_index', {status: 'pending'}) }}"
           class="underline hover:text-yellow-800 font-semibold">
            {{ pendingIntern }} Internal
        </a>
        &nbsp;·&nbsp;
        🚚
        <a href="{{ path('app_cmd_extern_index', {status: 'pending'}) }}"
           class="underline hover:text-yellow-800 font-semibold">
            {{ pendingExtern }} External
        </a>
    </p>
</div>

    {# Out of Stock #}
    <a href="{{ path('app_produit_index', {status: 'out_of_stock'}) }}" class="block transition hover:shadow-lg">
        <div class="bg-white p-5 rounded-xl shadow border-b-4 border-red-500 h-full">
            <div class="flex justify-between items-start">
                <p class="text-sm font-medium text-gray-500">Out of Stock</p>
                <span>❌</span>
            </div>
            <p class="text-3xl font-bold mt-2">{{ outOfStock }}</p>
            <p class="text-sm text-red-500 mt-2 font-semibold">Need Restocking</p>
        </div>
    </a>

</div>
        {# ── Quick Actions ── #}
        <div class="flex gap-4 mb-6 flex-shrink-0">
            <a href="{{ path('app_cmd_intern_new') }}"
               class="bg-blue-600 hover:bg-blue-700 text-white p-4 rounded-lg shadow flex-1 text-center font-bold transition-all flex items-center justify-center gap-2">
                🏭 New Internal Order
            </a>
            <a href="{{ path('app_cmd_extern_new') }}"
               class="bg-orange-500 hover:bg-orange-600 text-white p-4 rounded-lg shadow flex-1 text-center font-bold transition-all flex items-center justify-center gap-2">
                🚚 New External Order
            </a>
            <a href="{{ path('app_report_index') }}"
               class="bg-white border-2 border-gray-200 hover:bg-gray-50 text-gray-700 p-4 rounded-lg shadow-sm flex-1 text-center font-bold transition-all flex items-center justify-center gap-2">
                📊 View Reports →
            </a>
        </div>

        {# ── Bottom Grid — fills remaining height, cards scroll internally ── #}
        <div class="grid grid-cols-2 gap-6 flex-1 min-h-0">

            {# Low Stock Alerts #}
            <div class="bg-white p-6 rounded-xl shadow flex flex-col min-h-0">
                <h2 class="font-bold text-lg mb-4 flex items-center flex-shrink-0">
                    <span class="text-red-500 mr-2">⚠️</span> Low Stock Alerts
                </h2>
                <div class="overflow-y-auto flex-1 space-y-1 pr-1">
                    {% for item in lowStockAlerts %}
                        <div class="flex justify-between items-center border-b py-3 last:border-0">
                            <div>
                                <p class="font-bold text-gray-800">{{ item.designation }}</p>
                                <p class="text-sm text-gray-400 mt-0.5">Stock: {{ item.qteStock }}</p>
                            </div>
                            <span class="text-sm font-semibold text-orange-600 bg-orange-50 px-3 py-1 rounded-full whitespace-nowrap ml-4">
                                {{ item.seuilAlert }} (Threshold)
                            </span>
                        </div>
                    {% else %}
                        <p class="text-gray-400 text-center py-4">No low stock items found.</p>
                    {% endfor %}
                </div>
            </div>

            {# Recent Orders #}
            <div class="bg-white p-6 rounded-xl shadow flex flex-col min-h-0">
                <h2 class="font-bold text-lg mb-4 flex-shrink-0">Recent Orders</h2>
                <div class="overflow-y-auto flex-1 space-y-1 pr-1">
                    {% for order in recentOrders %}
                        <div class="flex justify-between items-center border-b py-3 last:border-0">
                            <div>
                                <p class="font-bold text-gray-800">ORD-{{ order.id }}</p>
                                <p class="text-sm text-gray-400 mt-0.5">
                                    {{ order.date ? order.date|date('d/m/Y') : '—' }}
                                    •
                                    <span class="{{ order.type == 'Internal' ? 'text-blue-500' : 'text-orange-500' }} font-semibold">
                                        {{ order.type }}
                                    </span>
                                </p>
                            </div>
                            
                            {% set badgeClass = 'bg-blue-100 text-blue-700' %}
                            {% if order.statut == 'Pending' %}
                                {% set badgeClass = 'bg-yellow-100 text-yellow-700' %}
                            {% elseif order.statut == 'Delivered' or order.statut == 'Received' %}
                                {% set badgeClass = 'bg-green-100 text-green-700' %}
                            {% elseif order.statut == 'Rejected' or order.statut == 'Cancelled' %}
                                {% set badgeClass = 'bg-red-100 text-red-700' %}
                            {% elseif order.statut == 'Draft' %}
                                {% set badgeClass = 'bg-gray-100 text-gray-600' %}
                            {% endif %}
                            <span class="px-3 py-1 rounded-full text-xs font-bold uppercase {{ badgeClass }} whitespace-nowrap ml-4">
                                {{ order.statut }}
                            </span>
                        </div>
                    {% else %}
                        <p class="text-gray-400 text-center py-4 text-sm">No recent orders found.</p>
                    {% endfor %}
                </div>
            </div>

        </div>
    </main>
</div>
{% endblock %}